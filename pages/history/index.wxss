page {
  height: 100%;
  background: #f5f7fa;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  position: relative;
  padding-left: 44rpx;
  margin-bottom: 32rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

.timeline-date {
  position: relative;
  margin-bottom: 18rpx;
}

.date-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  text-align: center;
}

.history-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-left: 18rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.version-time {
  font-size: 24rpx;
  color: #999;
}

.version-action {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.version-action.create {
  color: #4CAF50;
}

.version-action.update {
  color: #2196F3;
}

.version-action.delete {
  color: #F44336;
}

.version-action.restore {
  color: #FF9800;
}

.card-body {
  margin-bottom: 18rpx;
}

.expense-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.expense-title {
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.expense-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #667eea;
  text-align: center;
}

.backup-info {
  margin-top: 10rpx;
}

.backup-time {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 14rpx;
  text-align: center;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}