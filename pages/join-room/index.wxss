page {
  height: 100%;
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 32rpx 24rpx;
  padding-bottom: 60rpx;
}

.form-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 14rpx;
  text-align: center;
}

.form-input {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid transparent;
  text-align: center;
}

.form-input:focus {
  border-color: #4CAF50;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.error-message {
  background: #FFEBEE;
  border: 2rpx solid #F44336;
  color: #D32F2F;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.primary-button {
  background: #4CAF50;
  color: white;
  border-radius: 44rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 16rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
  text-align: center;
}

.divider {
  display: flex;
  align-items: center;
  margin: 36rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #eee;
}

.divider-text {
  padding: 0 28rpx;
  color: #999;
  font-size: 24rpx;
}

.secondary-button {
  background: white;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 44rpx;
  height: 96rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  text-align: center;
}

.info-card {
  background: #F9F9F9;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 20rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 18rpx;
  text-align: center;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  padding-left: 16rpx;
  position: relative;
  text-align: center;
}

.info-item::before {
  content: "•";
  position: absolute;
  left: 0;
  color: #4CAF50;
}