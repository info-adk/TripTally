page {
  height: 100%;
  background: linear-gradient(180deg, #f8f9ff 0%, #e8eeff 100%);
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.25);
  margin-bottom: 32rpx;
}

.summary-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 14rpx;
}

.summary-amount {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.summary-count {
  font-size: 24rpx;
  opacity: 0.8;
}

.settlement-section,
.balance-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 22rpx;
  padding-left: 12rpx;
  text-align: center;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.settlement-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.settlement-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.settlement-item:last-child {
  border-bottom: none;
}

.settlement-from,
.settlement-to {
  display: flex;
  align-items: center;
  flex: 1;
}

.settlement-to {
  justify-content: flex-end;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.from-avatar {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.to-avatar {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.user-info {
  margin-left: 14rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.user-role {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.settlement-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.arrow-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 8rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: #999;
}

.balance-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 12rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.balance-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.balance-item:last-child {
  border-bottom: none;
}

.balance-user {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.avatar-small {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.balance-name {
  margin-left: 14rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.balance-stats {
  display: flex;
  justify-content: space-between;
  padding-left: 62rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.stat-value.paid {
  color: #4facfe;
}

.stat-value.positive {
  color: #52c41a;
}

.stat-value.negative {
  color: #ff6b6b;
}

.action-buttons {
  padding: 20rpx 0;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.btn-confirm[disabled] {
  background: #ccc;
  color: #fff;
}