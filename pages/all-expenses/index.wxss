page {
  height: 100%;
  background: #f5f7fa;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 24rpx;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 36rpx;
}

.empty-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.expense-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.expense-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.expense-item:last-child {
  border-bottom: none;
}

.expense-left {
  flex: 1;
}

.expense-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.expense-category {
  font-size: 24rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.expense-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.expense-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  text-align: center;
}

.expense-meta {
  display: flex;
  gap: 24rpx;
}

.expense-date {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.expense-payer {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.expense-arrow {
  font-size: 48rpx;
  color: #ccc;
  margin-left: 24rpx;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #4CAF50;
  color: white;
  border-radius: 20rpx 20rpx 0 0;
}

.date-title {
  font-size: 28rpx;
  font-weight: bold;
}

.date-total {
  font-size: 28rpx;
  font-weight: bold;
}

.expense-time {
  font-size: 24rpx;
  color: #999;
}