page {
  height: 100%;
  background: #f5f7fa;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.room-card {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: white;
}

.room-name {
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-align: center;
}

.room-code-box {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.room-code-box .label {
  font-size: 26rpx;
  opacity: 0.9;
}

.room-code-box .code {
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 6rpx;
  margin: 0 20rpx;
}

.room-code-box .copy {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background: white;
  color: #4CAF50;
  border-radius: 8rpx;
}

.quick-btns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.quick-btn {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.quick-btn .icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.quick-btn text:last-child {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.members {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.member {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  flex-shrink: 0;
}

.avatar:not(image) {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.aa-card {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: white;
}

.aa-total {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.balances {
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
  padding: 16rpx;
}

.balance-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.positive {
  color: #C8E6C9;
}

.negative {
  color: #FFCDD2;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.view-more {
  text-align: center;
  padding: 24rpx 0;
  margin-top: 12rpx;
}

.view-more text {
  color: #4CAF50;
  font-size: 28rpx;
}

.expense-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.expense-item:last-child {
  border-bottom: none;
}

.expense-left {
  display: flex;
  flex-direction: column;
}

.expense-amount {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.expense-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
}

.expense-creator {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.expense-right {
  display: flex;
  align-items: center;
}

.expense-category {
  font-size: 24rpx;
  color: white;
  background: #4CAF50;
  padding: 6rpx 16rpx;
  border-radius: 14rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #4CAF50;
  color: white;
}

.btn-outline {
  background: white;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}