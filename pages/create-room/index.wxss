page {
  height: 100%;
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.form-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #4CAF50;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.error-message {
  background: #FFEBEE;
  border: 2rpx solid #F44336;
  color: #D32F2F;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.primary-button {
  background: #4CAF50;
  color: white;
  border-radius: 42rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 16rpx;
  margin-bottom: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.divider {
  display: flex;
  align-items: center;
  margin: 60rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #eee;
}

.divider-text {
  padding: 0 24rpx;
  color: #999;
  font-size: 24rpx;
}

.secondary-button {
  background: white;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 42rpx;
  height: 88rpx;
  line-height: 84rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.info-card {
  background: #F9F9F9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  padding-left: 16rpx;
  position: relative;
}

.info-item::before {
  content: "•";
  position: absolute;
  left: 0;
  color: #4CAF50;
}